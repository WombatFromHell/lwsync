{
  "manifest_version": 3,
  "name": "LWSync",
  "version": "1.0.0",
  "description": "Bidirectional sync between Linkwarden and browser bookmarks",
  "permissions": [
    "bookmarks",
    "storage",
    "unlimitedStorage",
    "alarms"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LWSync Settings",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "LWSync@localhost",
      "strict_min_version": "128.0"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
