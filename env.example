# Linkwarden API credentials (required for E2E tests)
API_KEY=<your Access Token generated in LinkWarden -> Settings>
ENDPOINT=https://linkwarden.somedomain.com

# Test collection configuration (used by test suite)
TEST_COLLECTION=114

# Optional: Custom collection name for tests (default: "Unorganized")
# TEST_COLLECTION_NAME=MyTestCollection

# Optional: Test timeout in milliseconds (default: 15000)
TEST_TIMEOUT=15000

# Optional: Enable verbose logging in tests
# VERBOSE=true
# DEBUG=true
